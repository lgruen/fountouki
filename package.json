{
  "name": "fountouki",
  "version": "0.1.0",
  "private": true,
  "description": "Tiny browser games for preschoolers.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch --serve",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "test": "node tools/unit-mode-test.mjs && node tools/sw-offline-test.mjs && node tools/playtest.mjs 30",
    "screenshots": "node tools/screenshots.mjs",
    "icons": "node tools/icons.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.6.3",
    "playwright": "^1.56.1"
  }
}
